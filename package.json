{
  "name": "flowkit",
  "version": "1.0.0",
  "description": "FlowKit - A beautiful, open-source widget system for chat interfaces. Like ChatKit, but yours.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts --format cjs,esm --external react,react-dom",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "keywords": [
    "chatkit",
    "widget",
    "chat",
    "flowkit",
    "react",
    "conversation",
    "ui",
    "components",
    "open-source"
  ],
  "author": "Open Source Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclawabdullah/flowkit"
  },
  "bugs": {
    "url": "https://github.com/openclawabdullah/flowkit/issues"
  },
  "homepage": "https://github.com/openclawabdullah/flowkit#readme"
}
